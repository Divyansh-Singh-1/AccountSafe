# =============================================================================
# AccountSafe - Frontend Environment Configuration Template
# =============================================================================
# Copy this file to `.env` in the same directory and customize the values.
# Do NOT commit `.env` containing sensitive credentials to version control.
# =============================================================================

# 1. APPLICATION BRANDING
# Customize the name of your application shown across the title and UI.
REACT_APP_PROJECT_NAME=AccountSafe

# 2. BACKEND API CONNECTION
# Development: http://localhost:8000/api/
# Production: https://api.yourdomain.com/api/
REACT_APP_API_URL=http://localhost:8000/api/

# 3. SECURITY & SESSION SETTINGS
# Clipboard Auto-Clear Timeout (in seconds) - cleared after copying passwords/sensitive fields
REACT_APP_CLIPBOARD_TIMEOUT=30

# Session Inactivity Timeout (in minutes) - user is auto-logged out after this duration
REACT_APP_SESSION_TIMEOUT=15

# 4. THIRD-PARTY SERVICES
# Cloudflare Turnstile Site Key for login/register bot protection (Site key is public)
# REACT_APP_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Brandfetch API Key (Optional - used to pull company logos automatically in the vault)
# Get a key from https://brandfetch.com/
# REACT_APP_BRANDFETCH_API_KEY=your_brandfetch_api_key_here
